# SDK 57 / React 19: some community packages (e.g. @react-native-community/
# datetimepicker 9.1.0 — the exact version expo bundledNativeModules.json
# expects) declare stale react peer ranges. legacy-peer-deps keeps npm from
# failing on those; real compatibility is validated by `npx expo install
# --check`. Applies to local installs, CI (npm ci), and EAS build servers.
legacy-peer-deps=true
