# Cappy environment variables
# Copy to .env (gitignored) and fill in. Never commit .env.

# Supabase (when backend is live)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# API base (the Cappy backend from the foundation kit, when deployed)
EXPO_PUBLIC_API_BASE_URL=https://api.cappy.closedose.com/v1

# Universal-links host (used for NFC tag URL prefix)
EXPO_PUBLIC_TAG_URL_HOST=cappy.closedose.com

# Feature flags
EXPO_PUBLIC_USE_MOCK_DATA=true
