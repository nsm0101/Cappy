# Cappy backend environment variables
# Copy to .env for local development. Never commit .env files.

# Runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cappy_dev

# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...      # SERVICE ROLE KEY - NEVER expose to client
SUPABASE_JWT_SECRET=your-jwt-secret    # for verifying tokens server-side

# Encryption
# Generate with: openssl rand -base64 32
CAPPY_MASTER_KEY_BASE64=REPLACE_ME_WITH_32_BYTES_BASE64
CAPPY_LOOKUP_HMAC_KEY_BASE64=REPLACE_ME_WITH_32_BYTES_BASE64

# KMS (production only)
KMS_KEY_ID=arn:aws:kms:us-east-1:000000000000:key/YOUR_KEY_ID
KMS_REGION=us-east-1

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
