{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/child-avatar/**",
              "components/dose-status/**",
              "preview/**",
              "ui_kits/app/**",
              "ui_kits/web/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Nunito Sans|Inter|DM Mono))/i]",
        "message": "Font not provided by the design system. Available: Nunito Sans, Inter, DM Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AvatarBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|color|key|ref|className|style|children)$/]",
        "message": "<AvatarBadge> doesn't accept that prop. Declared props: label, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='DoseStatusPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|size|label|dot|children|key|ref|className|style|children)$/]",
        "message": "<DoseStatusPill> doesn't accept that prop. Declared props: status, size, label, dot, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='DoseStatusPill'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<DoseStatusPill> size must be one of 'sm' | 'md'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
